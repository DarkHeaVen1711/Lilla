# ==============================================================================
# LILLA E-commerce Backend Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' and fill in your local or production credentials.
# Do not commit the actual '.env' file containing secrets to version control!

# ------------------------------------------------------------------------------
# Core Django Settings
# ------------------------------------------------------------------------------
# A secret key used for cryptographic signing. Keep it secure and unique in production!
DJANGO_SECRET_KEY="your-production-django-secret-key-here"

# Set to True for development, False for production.
DJANGO_DEBUG="True"

# Database Connection URL (e.g., PostgreSQL, MySQL, SQLite, etc.)
# If left blank, Django will default to using a local SQLite database (db.sqlite3).
# Example for PostgreSQL/Supabase: postgresql://username:password@hostname:5432/dbname
DATABASE_URL="postgresql://postgres:password@localhost:5432/lilla"

# ------------------------------------------------------------------------------
# Redis Cache Configuration
# ------------------------------------------------------------------------------
# Redis connection string used for caching (e.g., storing OTP verification pins).
# Defaults to local Redis db 1 if not specified.
REDIS_URL="redis://127.0.0.1:6379/1"

# ------------------------------------------------------------------------------
# CORS Origin Permissions
# ------------------------------------------------------------------------------
# Comma-separated list of origins allowed to make cross-origin requests.
# In development, the Next.js storefront runs on http://localhost:3000.
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# ------------------------------------------------------------------------------
# Next.js Cache Revalidation Integration
# ------------------------------------------------------------------------------
# The storefront URL endpoint that triggers Incremental Static Regeneration (ISR) revalidation.
NEXTJS_REVALIDATE_URL="http://localhost:3000/api/revalidate"

# Secure shared secret key to authenticate revalidation requests between Django and Next.js.
# Must match the REVALIDATION_SECRET configured in the Next.js frontend env.
REVALIDATION_SECRET="default_revalidation_secret"

# ------------------------------------------------------------------------------
# Passwordless OTP Gateway: Twilio Credentials
# ------------------------------------------------------------------------------
# Twilio Account SID and Auth Token to send OTP codes via SMS.
# If these are left blank, the backend will log/mock the SMS dispatch in the console.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ------------------------------------------------------------------------------
# Email SMTP Configuration
# ------------------------------------------------------------------------------
# Configure the email backend and SMTP server details.
# Defaults to the console backend for development (outputs email to console).
EMAIL_BACKEND="django.core.mail.backends.console.EmailBackend"
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USE_TLS="True"
EMAIL_HOST_USER=""
EMAIL_HOST_PASSWORD=""
DEFAULT_FROM_EMAIL="noreply@lilla.com"

# ------------------------------------------------------------------------------
# Anthropic Claude API Configuration
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY="your-anthropic-api-key-here"
# Sensible default model to prevent hardcoding model versions that might change.
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"
