# ==============================================================================
# LILLA E-commerce Storefront Environment Configuration Template
# ==============================================================================
# Copy this file to '.env.local' (for local development) or configure in your
# hosting provider (e.g. Vercel, Netlify) for production.
# Do not commit '.env.local' containing secrets to version control!

# ------------------------------------------------------------------------------
# API Connection Settings
# ------------------------------------------------------------------------------
# The base URL of the Django backend API.
# In local development, the Django server defaults to http://127.0.0.1:8000.
# In production, change this to your deployed backend URL.
NEXT_PUBLIC_API_URL="http://127.0.0.1:8000"

# ------------------------------------------------------------------------------
# Cache Revalidation Integration
# ------------------------------------------------------------------------------
# Secure shared secret key to validate Incremental Static Regeneration (ISR)
# revalidation requests coming from the Django backend.
# Must match the REVALIDATION_SECRET configured in the Django backend env.
REVALIDATION_SECRET="default_revalidation_secret"
